{
  "name": "image-deduper",
  "version": "0.1.0",
  "description": "Find duplicate images even when cropped, rotated, scaled, filtered, or watermarked.",
  "type": "module",
  "author": "Dustin Poissant <dustinpoissant@gmail.com>",
  "homepage": "https://github.com/dustinpoissant/image-deduper",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dustinpoissant/image-deduper.git"
  },
  "kempo-app": {
    "appName": "Image Deduper",
    "appIcon": "media/icon.png",
    "protocolName": "imagededuper",
    "shell": "shell.html",
    "pages": "pages"
  },
  "scripts": {
    "start": "kempo-app",
    "dev": "kempo-app --dev",
    "interact": "kempo-interact",
    "test": "kempo-test",
    "package": "kempo-app --package",
    "make": "kempo-app --make",
    "docs": "npx http-server docs -p 8080 -c-1"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@techstark/opencv-js": "4.12.0-release.1",
    "better-sqlite3": "^12.11.1",
    "kempo-app": "^0.0.28",
    "kempo-css": "latest",
    "kempo-ui": "^0.4.28",
    "sharp": "^0.35.0"
  },
  "overrides": {
    "sharp": "$sharp"
  }
}
